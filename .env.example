# Database Configuration
# Set DB_TYPE to 'sqlite' (default) or 'postgresql'
DB_TYPE=sqlite

# SQLite (automatic, no additional config needed)
# Database file will be at: database/runtime/store.db

# PostgreSQL Configuration (only needed if DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=billing_app
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
