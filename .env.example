# Flask Configuration
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=postgresql://billing:secure_password_change_me@localhost:5432/billing_agt
POSTGRES_DB=billing_agt
POSTGRES_USER=billing
POSTGRES_PASSWORD=secure_password_change_me
DB_TYPE=postgresql

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8000

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Redis Configuration (if using caching)
REDIS_URL=redis://localhost:6379/0

# AGT System Configuration
AGT_API_ENDPOINT=https://www.agt.gov.ao/api
AGT_SUBMISSION_TIMEOUT=30
AGT_RETRY_ATTEMPTS=3

# Certificate Configuration
CERTIFICATE_PATH=/etc/ssl/agt/private/certificate.pem
CERTIFICATE_KEY_PATH=/etc/ssl/agt/private/private.key
CERTIFICATE_PASSWORD=

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/var/log/billing_app/app.log
